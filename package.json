{
  "name": "mcp-server-lassox",
  "version": "0.2.0",
  "description": "MCP server for the Lassox CVR API.",
  "type": "module",
  "main": "./dist/stdio.js",
  "bin": {
    "mcp-server-lassox": "./dist/stdio.js"
  },
  "scripts": {
    "build": "tsup src/transports/stdio.ts src/transports/http.ts --format esm --dts --clean --sourcemap",
    "dev": "tsx src/transports/stdio.ts",
    "dev:http": "tsx src/transports/http.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke:live": "tsx test/live-smoke.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Borgels/mcp-server-lassox.git"
  },
  "keywords": [
    "mcp",
    "lassox",
    "cvr"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.11"
  },
  "bugs": {
    "url": "https://github.com/Borgels/mcp-server-lassox/issues"
  },
  "homepage": "https://github.com/Borgels/mcp-server-lassox#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "ip-address": ">=10.1.1",
    "hono": ">=4.12.16"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
