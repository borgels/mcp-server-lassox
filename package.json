{
  "name": "mcp-server-lassox",
  "version": "0.3.0",
  "description": "MCP server for the Lassox CVR API.",
  "type": "module",
  "main": "./dist/transports/stdio.js",
  "exports": {
    ".": "./dist/transports/stdio.js",
    "./gateway": {
      "types": "./dist/gateway.d.ts",
      "default": "./dist/gateway.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    ".env.example"
  ],
  "bin": {
    "mcp-server-lassox": "./dist/transports/stdio.js"
  },
  "scripts": {
    "build": "tsup src/transports/stdio.ts src/transports/http.ts src/gateway.ts --format esm --dts --clean --sourcemap",
    "dev": "tsx src/transports/stdio.ts",
    "dev:http": "tsx src/transports/http.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "npm run build",
    "prepack": "npm run typecheck && npm test && npm run build",
    "smoke:live": "tsx test/live-smoke.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borgels/mcp-server-lassox.git"
  },
  "keywords": [
    "mcp",
    "lassox",
    "cvr"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.11"
  },
  "bugs": {
    "url": "https://github.com/borgels/mcp-server-lassox/issues"
  },
  "homepage": "https://github.com/borgels/mcp-server-lassox#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "ip-address": ">=10.1.1",
    "hono": ">=4.12.25",
    "fast-uri": ">=3.1.2",
    "qs": ">=6.15.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
